# Obfusi-Bob Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Optional - will use in-memory if not configured)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=obfusibob
DB_USER=admin
DB_PASSWORD=secure_password

# JWT Configuration
JWT_SECRET=obfusibob-secret-key-change-in-production
JWT_EXPIRY=24h

# watsonx.ai Configuration (Optional - will use mock data if not configured)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_KEY=
WATSONX_PROJECT_ID=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# CORS Configuration
CORS_ORIGIN=*